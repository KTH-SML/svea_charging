<?xml version="1.0"?>
<launch>
    <arg name="is_sim" default="true"/>
    <arg name="use_mocap" default="true"/>
    <arg name="camera_image_topic" default="/svea67/image_raw"/>
    <arg name="camera_info_url" default="file:///svea_ws/src/svea_charging/params/camera/camera.yaml"/>
    <arg name="use_usb_cam" default="false"/>

    <arg name="use_aruco_camera" default="true"/>
    <arg name="aruco_dictionary" default="DICT_4X4_50"/>
    <arg name="aruco_marker_length_m" default="0.365"/>
    <arg name="aruco_display" default="false"/>
    <arg name="aruco_loop_hz" default="30.0"/>
    <arg name="aruco_frame_id" default="svea67/camera"/>
    <arg name="aruco_use_aruco_detector_api" default="false"/>
    <arg name="aruco_publish_debug_image" default="false"/>
    <arg name="aruco_jpeg_quality" default="80"/>
    <arg name="aruco_generate_marker_on_startup" default="false"/>
    <arg name="aruco_marker_id" default="13"/>
    <arg name="aruco_marker_size_px" default="400"/>
    <arg name="aruco_output" default="aruco_marker.png"/>
    <arg name="aruco_calibration_file" default="/svea_ws/src/svea_charging/params/camera/camera.yaml"/>
    <arg name="aruco_focal_length_px" default="-1.0"/>

    <arg name="manager_start_controller" default="stanley"/>
    <arg name="manager_switch_dist_to_goal_m" default="1.8"/>
    <arg name="manager_switch_aruco_distance_m" default="2.5"/>
    <arg name="manager_allow_switch_back" default="false"/>
    <arg name="mux_command_timeout_s" default="0.3"/>
    <arg name="localization_base_frame" default="base_link"/>

    <node if="$(var use_usb_cam)" name="usb_cam_node" pkg="usb_cam" exec="usb_cam_node_exe" output="screen">
        <param name="video_device" value="/dev/video0"/>
        <param name="frame_id" value="camera"/>
        <param name="pixel_format" value="mjpeg2rgb"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="framerate" value="30.0"/>
        <param name="camera_info_url" value="$(var camera_info_url)"/>
        <param name="brightness" value="150"/>
        <param name="gain" value="10"/>
        <param name="auto_white_balance" value="false"/>
        <param name="white_balance" value="4000"/>
        <param name="autoexposure" value="false"/>
        <param name="exposure" value="80"/>
        <param name="autofocus" value="false"/>
        <param name="focus" value="-1"/>

        <remap from="/image_raw" to="$(var camera_image_topic)"/>
        <remap from="/camera_info" to="/camera/camera_info"/>
    </node>

    <node name="stanleyExecutable" pkg="svea_charging" exec="stanleyExecutable.py" output="screen">
        <param name="is_sim" value="$(var is_sim)"/>
        <param name="use_mocap" value="$(var use_mocap)"/>
        <param name="localization/base_frame" value="$(var localization_base_frame)"/>
    </node>

    <node name="line_follower" pkg="svea_charging" exec="line_follower.py" output="screen">
        <param name="is_sim" value="$(var is_sim)"/>
        <param name="image_topic" value="$(var camera_image_topic)"/>
    </node>

    <node if="$(var use_aruco_camera)" name="aruco_camera_test" pkg="svea_charging" exec="aruco_camera_test.py" output="screen">
        <param name="dictionary" value="$(var aruco_dictionary)"/>
        <param name="marker_length_m" value="$(var aruco_marker_length_m)"/>
        <param name="display" value="$(var aruco_display)"/>
        <param name="loop_hz" value="$(var aruco_loop_hz)"/>
        <param name="frame_id" value="$(var aruco_frame_id)"/>
        <param name="use_aruco_detector_api" value="$(var aruco_use_aruco_detector_api)"/>
        <param name="publish_debug_image" value="$(var aruco_publish_debug_image)"/>
        <param name="jpeg_quality" value="$(var aruco_jpeg_quality)"/>
        <param name="generate_marker_on_startup" value="$(var aruco_generate_marker_on_startup)"/>
        <param name="marker_id" value="$(var aruco_marker_id)"/>
        <param name="marker_size_px" value="$(var aruco_marker_size_px)"/>
        <param name="output" value="$(var aruco_output)"/>
        <param name="calibration_file" value="$(var aruco_calibration_file)"/>
        <param name="focal_length_px" value="$(var aruco_focal_length_px)"/>
        <param name="image_topic" value="$(var camera_image_topic)"/>
    </node>

    <node name="mission_manager" pkg="svea_charging" exec="mission_manager.py" output="screen">
        <param name="start_controller" value="$(var manager_start_controller)"/>
        <param name="switch_dist_to_goal_m" value="$(var manager_switch_dist_to_goal_m)"/>
        <param name="switch_aruco_distance_m" value="$(var manager_switch_aruco_distance_m)"/>
        <param name="allow_switch_back" value="$(var manager_allow_switch_back)"/>
    </node>

    <node name="control_mux" pkg="svea_charging" exec="control_mux.py" output="screen">
        <param name="command_timeout_s" value="$(var mux_command_timeout_s)"/>
    </node>
</launch>
